# ==========================================
# SENNOVA Frontend - Variables de Entorno
# ==========================================
# Copiar este archivo a .env.local para desarrollo
# En producción (Coolify), estas variables se configuran
# en el panel de Environment Variables
# ==========================================

# ==========================================
# API CONFIGURATION (REQUERIDO)
# ==========================================
# URL del backend API
# En desarrollo local: http://localhost:8000
# En producción con proxy: /api (ruta relativa)
# En producción sin proxy: https://api.tudominio.com
VITE_API_URL=http://localhost:8000

# URL base del servicio CVLAC de Colciencias (para placeholders)
VITE_CVLAC_BASE_URL=http://scienti.colciencias.gov.co:8084

# URL interna del backend (para referencia/debug)
# En local: http://localhost:8000
# En Docker: http://sennova-backend:8000
VITE_BACKEND_URL=http://localhost:8000

# ==========================================
# FEATURE FLAGS (Opcional)
# ==========================================
# Habilitar/deshabilitar funcionalidades
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_PANEL=false

# ==========================================
# NOTAS PARA PRODUCCIÓN
# ==========================================
# 1. NUNCA commitear el archivo .env.local real
# 2. En Coolify/Vercel/Netlify, configurar variables
#    directamente en el panel de administración
# 3. Las variables VITE_ son expuestas al cliente,
#    NO incluir secrets aquí (usar proxy en su lugar)
# ==========================================
