# ==========================================
# SENNOVA CGAO - Variables de Entorno
# Configuración para Desarrollo y Producción
# REGLA ANTI-HARDCODING: Todas las configuraciones DEBEN estar aquí
# ==========================================

# ==========================================
# 🗄️ BASE DE DATOS (PostgreSQL)
# ==========================================
# URL completa de conexión (opcional - se construye automáticamente si no se proporciona)
# DATABASE_URL=postgresql://sennova:password@localhost:5432/sennova

# Componentes individuales de conexión (usados si DATABASE_URL no está definida)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sennova
DB_USER=sennova
DB_PASSWORD=sennova_secure_password_2024

# ==========================================
# 🔐 SEGURIDAD - JWT (CRÍTICO)
# ==========================================
# JWT_SECRET: Mínimo 32 caracteres aleatorios en producción
# Generar con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# JWT_ALGORITHM: Algoritmo de firma (default: HS256)
JWT_ALGORITHM=HS256

# JWT_EXPIRATION_HOURS: Tiempo de expiración del token en horas
JWT_EXPIRATION_HOURS=24

# ==========================================
# 👤 USUARIO ADMINISTRADOR INICIAL
# ==========================================
INITIAL_ADMIN_EMAIL=admin@sena.edu.co
INITIAL_ADMIN_PASSWORD=admin_secure_password_2024

# ==========================================
# 🌐 CORS - Orígenes permitidos (CRÍTICO PARA PRODUCCIÓN)
# ==========================================
# Lista de orígenes permitidos separados por comas
# En producción (Coolify): Solo el dominio de producción
# Ejemplo: https://sennova.enlinea.sbs
# 
# IMPORTANTE: NO incluir http://localhost en producción
# Si usas proxy nginx, solo necesitas el dominio del frontend
# ==========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Orígenes CORS adicionales para desarrollo (solo cuando DEBUG=true)
# Separados por comas. Solo usados en modo desarrollo.
ADDITIONAL_CORS_ORIGINS=http://localhost:3110,http://localhost:3100,http://localhost:3005

# ==========================================
# 🖥️ SERVIDOR BACKEND
# ==========================================
# HOST: Interface donde escuchar (127.0.0.1 para local, 0.0.0.0 para Docker)
HOST=127.0.0.1

# PORT: Puerto del servidor backend
PORT=8000

# ==========================================
# 🚀 FRONTEND - URLs y Configuración API
# ==========================================
# VITE_API_URL: URL del backend para el frontend
# Opción A - Proxy interno (recomendado): /api
# Opción B - URL completa: https://api.dominio.com
VITE_API_URL=http://localhost:8000

# URL pública del frontend (para links en emails, etc.)
FRONTEND_URL=http://localhost:5173

# URL pública del backend (para webhooks, callbacks)
BACKEND_URL=http://localhost:8000

# ==========================================
# 📧 PGADMIN (Administración PostgreSQL)
# ==========================================
PGADMIN_EMAIL=admin@sena.edu.co
PGADMIN_PASSWORD=pgadmin_secure_password_2024

# ==========================================
# ⚙️ CONFIGURACIÓN DE LA APLICACIÓN
# ==========================================
# DEBUG: Modo debug (true en desarrollo, false en producción)
DEBUG=true

# APP_NAME: Nombre de la aplicación
APP_NAME=SENNOVA CGAO API

# ==========================================
# 🔧 CONFIGURACIÓN AVANZADA (Opcional)
# ==========================================
# LOG_LEVEL: Nivel de logging (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# MAX_UPLOAD_SIZE: Tamaño máximo de archivos en MB
# MAX_UPLOAD_SIZE=50

# RATE_LIMIT_PER_MINUTE: Límite de peticiones por minuto
# RATE_LIMIT_PER_MINUTE=60

# CVLAC_BASE_URL: URL base del servicio CVLAC de Colciencias
# CVLAC_BASE_URL=https://scienti.minciencias.gov.co

# ==========================================
# 📋 CHECKLIST PARA PRODUCCIÓN EN COOLIFY
# ==========================================
# ✅ 1. JWT_SECRET: Generar clave segura de 32+ caracteres
# ✅ 2. DB_PASSWORD: Contraseña fuerte (12+ caracteres)
# ✅ 3. ALLOWED_ORIGINS: Solo dominio de producción (sin localhost)
# ✅ 4. VITE_API_URL: '/api' para proxy nginx o URL completa
# ✅ 5. DEBUG: Cambiar a 'false'
# ✅ 6. COPIAR este archivo a .env (NO commitear .env real)
# ✅ 7. Verificar que .env está en .gitignore
# ==========================================

# ==========================================
# 🚨 SEGURIDAD - NO COMPARTIR
# ==========================================
# NUNCA compartir el archivo .env real
# NUNCA hardcodear estos valores en el código
# NUNCA subir .env a repositorios públicos
# ==========================================
