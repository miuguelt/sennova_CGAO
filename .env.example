# ==========================================
# SENNOVA CGAO - Variables de Entorno
# Configuración para Desarrollo y Producción
# ==========================================

# ==========================================
# BASE DE DATOS (PostgreSQL)
# ==========================================
DB_PASSWORD=sennova_secure_password_2024

# ==========================================
# SEGURIDAD - JWT
# IMPORTANTE: Cambiar en producción con contraseña de mínimo 32 caracteres
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# ==========================================
# USUARIO ADMINISTRADOR INICIAL
# ==========================================
INITIAL_ADMIN_EMAIL=admin@sena.edu.co
INITIAL_ADMIN_PASSWORD=admin_secure_password_2024

# ==========================================
# PGADMIN (Administración PostgreSQL)
# ==========================================
PGADMIN_EMAIL=admin@sena.edu.co
PGADMIN_PASSWORD=pgadmin_secure_password_2024

# ==========================================
# CORS - Orígenes permitidos (separados por comas)
# En producción, incluir el dominio de Coolify
# Ejemplo: https://sennova.tucoolify.app,https://api-sennova.tucoolify.app
# ==========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# ==========================================
# FRONTEND - URL del Backend API
# En desarrollo: http://localhost:8000
# En producción: https://api-tudominio.com
# ==========================================
VITE_API_URL=http://localhost:8000

# ==========================================
# NOTAS PARA PRODUCCIÓN EN COOLIFY:
# ==========================================
# 1. Copiar este archivo a .env y configurar valores seguros
# 2. JWT_SECRET debe tener mínimo 32 caracteres aleatorios
# 3. DB_PASSWORD debe ser fuerte (mínimo 12 caracteres)
# 4. ALLOWED_ORIGINS debe incluir el dominio de Coolify
# 5. VITE_API_URL debe apuntar al backend en Coolify
# ==========================================
